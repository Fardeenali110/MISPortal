@model MisProject.Models.Department

@{
    ViewBag.Title = "Edit Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header">
                <h4><i class="fas fa-edit"></i> Edit Department</h4>
            </div>
            <div class="card-body">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.DepartmentId)
                    @Html.HiddenFor(model => model.CreatedDate)

                    <div class="form-group mb-3">
                        @Html.LabelFor(model => model.DepartmentCode)
                        @Html.TextBoxFor(model => model.DepartmentCode, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.DepartmentCode, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group mb-3">
                        @Html.LabelFor(model => model.DepartmentName)
                        @Html.TextBoxFor(model => model.DepartmentName, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.DepartmentName, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group mb-3">
                        @Html.LabelFor(model => model.Description)
                        @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = "3" })
                    </div>

                    <div class="form-group mb-3">
                        @Html.LabelFor(model => model.IsActive)
                        <div class="form-check form-switch mt-2">
                            @Html.CheckBoxFor(model => model.IsActive, new { @class = "form-check-input" })
                            <label class="form-check-label" for="IsActive">Active Department</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Update Department
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}