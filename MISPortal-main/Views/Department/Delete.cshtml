@model MisProject.Models.Department

@{
    ViewBag.Title = "Delete Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h4><i class="fas fa-trash"></i> Delete Department</h4>
            </div>
            <div class="card-body">
                <h5>Are you sure you want to delete this department?</h5>

                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> Note: If this department has employees, they will lose their department assignment.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Department Code:</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.DepartmentCode)</dd>

                    <dt class="col-sm-4">Department Name:</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.DepartmentName)</dd>

                    <dt class="col-sm-4">Description:</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Description)</dd>

                    <dt class="col-sm-4">Created Date:</dt>
                    <dd class="col-sm-8">@Model.CreatedDate.ToString("yyyy-MM-dd")</dd>
                </dl>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.DepartmentId)

                    <div class="form-group">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Confirm Delete
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>