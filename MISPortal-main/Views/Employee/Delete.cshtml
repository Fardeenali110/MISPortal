@model MisProject.Models.Employee

@{
    ViewBag.Title = "Delete Employee";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h4><i class="fas fa-trash"></i> Delete Employee</h4>
            </div>
            <div class="card-body">
                <h5>Are you sure you want to delete this employee?</h5>

                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> This action cannot be undone!
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Employee Code:</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.EmployeeCode)</dd>

                    <dt class="col-sm-4">Name:</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.FullName)</dd>

                    <dt class="col-sm-4">Email:</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Email)</dd>

                    <dt class="col-sm-4">Designation:</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Designation)</dd>

                    <dt class="col-sm-4">Joining Date:</dt>
                    <dd class="col-sm-8">@Model.JoiningDate.ToString("yyyy-MM-dd")</dd>
                </dl>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.EmployeeId)

                    <div class="form-group">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Confirm Delete
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>