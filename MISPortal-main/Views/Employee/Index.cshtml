@model IEnumerable<MisProject.Models.Employee>

@{
    ViewBag.Title = "Employees";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <h2><i class="fas fa-users"></i> Employee Management</h2>
        <hr />
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mb-3">
    <div class="col-md-8">
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New Employee
        </a>
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="fas fa-sync"></i> Refresh
        </a>
    </div>
    <div class="col-md-4">
        @using (Html.BeginForm("Index", "Employee", FormMethod.Get))
        {
            <div class="input-group">
                <input type="text" class="form-control" name="searchString" placeholder="Search employees..." value="@ViewBag.CurrentFilter">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fas fa-search"></i> Search
                </button>
            </div>
        }
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5>Employee List</h5>
                <small class="text-muted">Total Employees: @Model.Count()</small>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>@Html.ActionLink("Employee Code", "Index", new { sortOrder = ViewBag.CodeSort })</th>
                                <th>@Html.ActionLink("Name", "Index", new { sortOrder = ViewBag.NameSort })</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Department</th>
                                <th>@Html.ActionLink("Joining Date", "Index", new { sortOrder = ViewBag.DateSort })</th>
                                <th>Designation</th>
                                <th>Salary</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@Html.DisplayFor(modelItem => item.EmployeeCode)</td>
                                    <td>@item.FirstName @item.LastName</td>
                                    <td>@Html.DisplayFor(modelItem => item.Email)</td>
                                    <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                                    <td>
                                        @if (item.Department != null)
                                        {
                                            <span class="badge bg-info">@item.Department.DepartmentName</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Not Assigned</span>
                                        }
                                    </td>
                                    <td>@item.JoiningDate.ToString("yyyy-MM-dd")</td>
                                    <td>@Html.DisplayFor(modelItem => item.Designation)</td>
                                    <td>@Html.DisplayFor(modelItem => item.Salary)</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="@Url.Action("Details", new { id = item.EmployeeId })" class="btn btn-info" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", new { id = item.EmployeeId })" class="btn btn-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = item.EmployeeId })" class="btn btn-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (!Model.Any())
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-users fa-3x text-muted mb-3"></i>
                            <h5>No employees found</h5>
                            <p>Click "Add New Employee" to create your first employee record.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>