<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MIS Portal</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            padding-top: 56px;
        }

        .sidebar {
            width: 220px;
        }

        .main-content {
            margin-left: 220px;
        }

        .footer {
            margin-left: 220px;
        }

        @@media (max-width: 768px) {
            .sidebar, .main-content, .footer {
                width: 100%;
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="fas fa-chart-line mr-2"></i> MIS Portal
            </a>

            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home mr-1"></i> Home
                        </a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="managementDropdown"
                               data-toggle="dropdown">
                                <i class="fas fa-cog mr-1"></i> Management
                            </a>
                            <div class="dropdown-menu">
                                <!-- Check controller names - CHANGE HERE -->
                                <a class="dropdown-item" href="@Url.Action("Index", "Employee")">
                                    <i class="fas fa-users mr-2"></i> Employees
                                </a>
                                <a class="dropdown-item" href="@Url.Action("Index", "Department")">
                                    <i class="fas fa-building mr-2"></i> Departments
                                </a>
                                <a class="dropdown-item" href="@Url.Action("Index", "Attendance")">
                                    <i class="fas fa-calendar-check mr-2"></i> Attendance
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" href="@Url.Action("ManageUsers", "Account")">
                                        <i class="fas fa-user-cog mr-2"></i> Users
                                    </a>
                                }
                            </div>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="reportsDropdown"
                               data-toggle="dropdown">
                                <i class="fas fa-chart-bar mr-1"></i> Reports
                            </a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="@Url.Action("Report", "Attendance")">
                                    <i class="fas fa-file-excel mr-2"></i> Attendance Reports
                                </a>
                            </div>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown"
                               data-toggle="dropdown">
                                <i class="fas fa-user-circle mr-1"></i>
                                @User.Identity.Name
                            </a>
                            <div class="dropdown-menu dropdown-menu-right">
                                <a class="dropdown-item" href="@Url.Action("Profile", "Account")">
                                    <i class="fas fa-user mr-2"></i> Profile
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a class="dropdown-item" href="@Url.Action("ManageUsers", "Account")">
                                        <i class="fas fa-users-cog mr-2"></i> Manage Users
                                    </a>
                                }
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="@Url.Action("Logout", "Account")">
                                    <i class="fas fa-sign-out-alt mr-2"></i> Logout
                                </a>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">
                                <i class="fas fa-sign-in-alt mr-1"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Register", "Account")">
                                <i class="fas fa-user-plus mr-1"></i> Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content with Sidebar -->
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar (Only show when logged in) -->
            @if (User.Identity.IsAuthenticated)
            {
                <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar">
                    <div class="position-sticky pt-3">
                        <!-- Management Section -->
                        <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                            <span>Management</span>
                        </h6>
                        <ul class="nav flex-column mb-2">
                            <!-- CHECK CONTROLLER NAMES HERE -->
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Employee")">
                                    <i class="fas fa-users mr-2"></i> Employees
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Department")">
                                    <i class="fas fa-building mr-2"></i> Departments
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Attendance")">
                                    <i class="fas fa-calendar-check mr-2"></i> Attendance
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="@Url.Action("ManageUsers", "Account")">
                                        <i class="fas fa-user-cog mr-2"></i> Users
                                    </a>
                                </li>
                            }
                        </ul>

                        <!-- Reports Section -->
                        <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                            <span>Reports</span>
                        </h6>
                        <ul class="nav flex-column mb-2">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Report", "Attendance")">
                                    <i class="fas fa-file-excel mr-2"></i> Attendance Reports
                                </a>
                            </li>
                        </ul>

                        <!-- Quick Actions -->
                        <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                            <span>Quick Actions</span>
                        </h6>
                        <ul class="nav flex-column mb-2">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("MarkAttendance", "Attendance")">
                                    <i class="fas fa-plus-circle mr-2"></i> Mark Attendance
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("AddToday", "Attendance")">
                                    <i class="fas fa-bolt mr-2"></i> Quick Mark All
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>
            }

            <!-- Main Content Area -->
            <main class="@(User.Identity.IsAuthenticated ? "col-md-9 ms-sm-auto col-lg-10" : "col-12") px-md-4 main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Footer -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; @DateTime.Now.Year - MIS Portal - <span class="text-primary">Management Information System</span>
        </div>
    </footer>

    <!-- Scripts -->
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

    <script>
        $(document).ready(function () {
            // Active link highlighting
            var currentUrl = window.location.pathname.toLowerCase();

            $('.nav-link').each(function () {
                var linkUrl = $(this).attr('href').toLowerCase();
                if (currentUrl === linkUrl ||
                    (linkUrl !== '#' && currentUrl.indexOf(linkUrl) > -1)) {
                    $(this).addClass('active');
                    $(this).closest('.nav-item').addClass('active');
                }
            });

            // Auto-close mobile navbar when clicking a link
            $('.navbar-nav .nav-link').on('click', function () {
                $('.navbar-collapse').collapse('hide');
            });
        });
    </script>
</body>
</html>