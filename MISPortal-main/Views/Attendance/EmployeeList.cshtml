@model IEnumerable<MisProject.Controllers.AttendanceController.EmployeeDto>

@{
    ViewBag.Title = "Select Employee";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <h2><i class="fas fa-users"></i> Select Employee</h2>
            <p class="text-muted">Select an employee to view attendance history</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Active Employees</h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="row">
                            @foreach (var emp in Model)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card employee-card">
                                        <div class="card-body text-center">
                                            <div class="avatar-circle mb-3">
                                                <i class="fas fa-user fa-2x"></i>
                                            </div>
                                            <h5>@emp.FirstName @emp.LastName</h5>
                                            <p class="text-muted">Code: @emp.EmployeeCode</p>
                                            <a href="@Url.Action("EmployeeAttendance", new { id = emp.EmployeeId })"
                                               class="btn btn-primary btn-sm">
                                                <i class="fas fa-history me-1"></i> View Attendance History
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-users-slash fa-3x text-muted mb-3"></i>
                            <h5>No Employees Found</h5>
                            <p class="text-muted">No active employees in the system.</p>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Back to Attendance
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .employee-card {
        transition: transform 0.3s;
    }

        .employee-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    .avatar-circle {
        width: 60px;
        height: 60px;
        background-color: #f8f9fa;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #dee2e6;
    }
</style>