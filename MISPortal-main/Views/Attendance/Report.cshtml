@model IEnumerable<MisProject.Controllers.AttendanceController.AttendanceReportDto>

@{
    ViewBag.Title = "Attendance Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <h2><i class="fas fa-chart-bar"></i> Attendance Report</h2>
        <hr />
    </div>
</div>

@using (Html.BeginForm("Report", "Attendance", FormMethod.Post))
{
    <div class="row mb-4">
        <div class="col-md-3">
            <label>From Date</label>
            <input type="date" name="fromDate" class="form-control"
                   value="@ViewBag.FromDate" required />
        </div>
        <div class="col-md-3">
            <label>To Date</label>
            <input type="date" name="toDate" class="form-control"
                   value="@ViewBag.ToDate" required />
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">
                <i class="fas fa-search"></i> Generate Report
            </button>

            @if (Model != null && Model.Any())
            {
                <button type="submit" name="exportType" value="excel"
                        class="btn btn-success me-2">
                    <i class="fas fa-file-excel"></i> Export Excel
                </button>

                <button type="submit" name="exportType" value="csv"
                        class="btn btn-info">
                    <i class="fas fa-file-csv"></i> Export CSV
                </button>
            }
        </div>
    </div>
}

@if (Model != null)
{
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="alert alert-info">
                <h5>
                    <i class="fas fa-calendar-alt"></i>
                    Report Period: @ViewBag.FromDate to @ViewBag.ToDate
                </h5>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Total Employees</h6>
                            <h3>@ViewBag.TotalEmployees</h3>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Total Present</h6>
                            <h3>@ViewBag.TotalPresent</h3>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-check-circle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Total Absent</h6>
                            <h3>@ViewBag.TotalAbsent</h3>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-times-circle fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Overall %</h6>
                            <h3>@ViewBag.OverallPercentage%</h3>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-chart-line fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5>Detailed Attendance Report</h5>
                    <p class="mb-0 text-muted">Showing @Model.Count() employee(s)</p>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Employee Code</th>
                                    <th>Employee Name</th>
                                    <th>Department</th>
                                    <th>Present</th>
                                    <th>Absent</th>
                                    <th>Leave</th>
                                    <th>Total Days</th>
                                    <th>Percentage</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int counter = 1;
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@counter</td>
                                            <td>@item.EmployeeCode</td>
                                            <td>@item.EmployeeName</td>
                                            <td>@item.DepartmentName</td>
                                            <td>
                                                <span class="badge bg-success">@item.PresentDays</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-danger">@item.AbsentDays</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-warning">@item.LeaveDays</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-info">@item.TotalDays</span>
                                            </td>
                                            <td>
                                                <div class="progress" style="height: 20px;">
                                                    @{
                                                        int percentage = (int)item.AttendancePercentage;
                                                        string progressClass = "bg-success";
                                                        if (percentage < 75)
                                                        {
                                                            progressClass = "bg-danger";
                                                        }
                                                        else if (percentage < 90)
                                                        {
                                                            progressClass = "bg-warning";
                                                        }

                                                        int progressWidth = percentage > 100 ? 100 : percentage;
                                                    }
                                                    <div class="progress-bar @progressClass"
                                                         role="progressbar"
                                                         style="width: @progressWidth%"
                                                         aria-valuenow="@percentage"
                                                         aria-valuemin="0"
                                                         aria-valuemax="100">
                                                        @item.AttendancePercentage.ToString("0.00")%
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (item.AttendancePercentage >= 90)
                                                {
                                                    <span class="badge bg-success">Excellent</span>
                                                }
                                                else if (item.AttendancePercentage >= 75)
                                                {
                                                    <span class="badge bg-warning">Good</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Poor</span>
                                                }
                                            </td>
                                        </tr>
                                        counter++;
                                    }
                                }
                            </tbody>
                            @if (Model.Any())
                            {
                                <tfoot class="table-secondary">
                                    <tr>
                                        <td colspan="4" class="text-end"><strong>TOTAL</strong></td>
                                        <td><strong>@Model.Sum(m => m.PresentDays)</strong></td>
                                        <td><strong>@Model.Sum(m => m.AbsentDays)</strong></td>
                                        <td><strong>@Model.Sum(m => m.LeaveDays)</strong></td>
                                        <td><strong>@Model.Sum(m => m.TotalDays)</strong></td>
                                        <td>
                                            <strong>
                                                @Math.Round(Model.Average(m => m.AttendancePercentage), 2)%
                                            </strong>
                                        </td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            }
                        </table>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-chart-line fa-4x text-muted mb-3"></i>
                            <h4>No Attendance Data Found</h4>
                            <p class="text-muted">No attendance records found for the selected period.</p>
                            <div class="mt-3">
                                <a href="/Attendance/AddSampleAttendance" class="btn btn-success">
                                    <i class="fas fa-bolt"></i> Add Sample Data
                                </a>
                                <a href="/Attendance" class="btn btn-primary">
                                    <i class="fas fa-calendar-check"></i> Go to Attendance
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}